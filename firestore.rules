rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn()
        && userDoc().data.role == 'ADMIN';
    }

    function isContestantVisibleTournament(data) {
      return data.visibility == 'visible'
        && data.status in ['published', 'live', 'completed'];
    }

    // Users collection
    // - Users can read their own profile
    // - Admins can read all profiles
    // - Users can create their own profile on first sign-in
    // - Users can update their own profile (excluding protected fields)
    // - Admins can update user status, lock/unlock accounts
    // - Only admins can delete users
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && !isProtectedFieldUpdate())
        || isAdmin()
      );
      allow delete: if isAdmin();

      // Helper: Check if update attempts to modify protected fields (contestants only)
      function isProtectedFieldUpdate() {
        let protectedFields = ['uid', 'role', 'status', 'provider', 'statistics', 'createdAt', 'lockedBy', 'lockedAt', 'lockReason'];
        return request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedFields);
      }
    }

    match /tournaments/{tournamentId} {
      allow read: if isAdmin() || (isSignedIn() && isContestantVisibleTournament(resource.data));
      allow create, update, delete: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    function isContestantVisibleMatch(data) {
      return data.visible == true
        && data.status in ['published', 'prediction_open', 'prediction_locked', 'live', 'completed', 'result_published'];
    }

    match /matches/{matchId} {
      allow read: if isAdmin() || (isSignedIn() && isContestantVisibleMatch(resource.data));
      allow create, update, delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /predictions/{predictionId} {
      allow read: if isSignedIn() && (
        isAdmin()
        || resource.data.userId == request.auth.uid
      );
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && userDoc().data.status == 'ACTIVE';
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && userDoc().data.status == 'ACTIVE';
      allow delete: if isAdmin();
    }

    match /settings/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /leaderboard_cache/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
